---
const {
  title = '777stay 技术博客',
  description = '后端开发、系统设计、AI 工具链、源码阅读和项目复盘。',
} = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #08090a;
        --bg-soft: #0d0f12;
        --panel: rgba(255, 255, 255, 0.035);
        --panel-strong: rgba(255, 255, 255, 0.06);
        --ink: #f7f8f8;
        --muted: #a1a7b3;
        --subtle: #626975;
        --line: rgba(255, 255, 255, 0.09);
        --line-soft: rgba(255, 255, 255, 0.055);
        --accent: #7c87ff;
        --accent-strong: #5e6ad2;
        --green: #10b981;
        --pink: #de1d8d;
        --blue: #0a72ef;
        --shadow: 0 0 0 1px var(--line), 0 24px 80px rgba(0, 0, 0, 0.36);
        --shadow-soft: 0 0 0 1px var(--line-soft), 0 16px 48px rgba(0, 0, 0, 0.26);
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: 'Geist', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans SC", "PingFang SC", sans-serif;
        font-feature-settings: "liga" 1;
        background:
          radial-gradient(circle at 18% -10%, rgba(124, 135, 255, 0.26), transparent 34rem),
          radial-gradient(circle at 85% 12%, rgba(10, 114, 239, 0.13), transparent 30rem),
          linear-gradient(180deg, #08090a 0%, #0b0d10 48%, #08090a 100%);
        color: var(--ink);
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(255,255,255,0.026) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.026) 1px, transparent 1px);
        background-size: 56px 56px;
        mask-image: linear-gradient(to bottom, black, transparent 72%);
      }
      a { color: inherit; text-decoration: none; }
      a:hover { color: var(--ink); }
      .shell { width: min(1120px, calc(100% - 40px)); margin: 0 auto; }
      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        padding: 16px 0;
        backdrop-filter: blur(18px);
        background: rgba(8, 9, 10, 0.72);
        border-bottom: 1px solid var(--line-soft);
      }
      nav { display: flex; justify-content: space-between; align-items: center; gap: 20px; }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
        letter-spacing: -0.03em;
        font-size: 0.98rem;
      }
      .brand-mark {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        display: inline-grid;
        place-items: center;
        background: linear-gradient(135deg, var(--accent), var(--blue));
        color: white;
        font-family: 'Geist Mono', ui-monospace, monospace;
        font-size: 12px;
        box-shadow: 0 0 24px rgba(124, 135, 255, 0.34);
      }
      .nav-links { display: flex; gap: 8px; align-items: center; color: var(--muted); font-size: 0.92rem; }
      .nav-links a {
        padding: 8px 11px;
        border-radius: 999px;
        transition: background .18s ease, color .18s ease;
      }
      .nav-links a:hover { background: rgba(255,255,255,0.06); color: var(--ink); }
      main { padding: 58px 0 92px; position: relative; }
      .card {
        background: linear-gradient(180deg, var(--panel-strong), var(--panel));
        border: 1px solid var(--line);
        border-radius: 24px;
        box-shadow: var(--shadow-soft);
      }
      .hero {
        padding: clamp(34px, 7vw, 82px);
        position: relative;
        overflow: hidden;
      }
      .hero::after {
        content: "";
        position: absolute;
        width: 460px;
        height: 460px;
        right: -180px;
        top: -170px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(124,135,255,.22), transparent 62%);
        pointer-events: none;
      }
      .eyebrow {
        color: var(--accent);
        font-family: 'Geist Mono', ui-monospace, monospace;
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        margin: 0 0 14px;
      }
      h1, h2, h3 { line-height: 1.06; letter-spacing: -0.055em; text-wrap: balance; }
      h1 { font-size: clamp(2.55rem, 8vw, 6.2rem); margin: 0 0 22px; }
      h2 { font-size: clamp(1.55rem, 3.5vw, 2.55rem); margin: 0; }
      h3 { font-size: 1.06rem; letter-spacing: -0.025em; margin: 0; }
      .lead { color: var(--muted); font-size: clamp(1.03rem, 2vw, 1.25rem); max-width: 760px; margin: 0; }
      .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 30px; }
      .button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 42px;
        padding: 0 16px;
        border-radius: 10px;
        font-weight: 500;
        font-size: 0.94rem;
        transition: transform .18s ease, background .18s ease, border-color .18s ease;
      }
      .button:hover { transform: translateY(-1px); }
      .button.primary { background: var(--ink); color: #08090a; }
      .button.ghost { background: rgba(255,255,255,0.035); border: 1px solid var(--line); color: var(--ink); }
      .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-top: 18px; }
      .tile { padding: 24px; min-height: 168px; transition: transform .18s ease, background .18s ease, border-color .18s ease; }
      .tile:hover, .post:hover { transform: translateY(-2px); background: rgba(255,255,255,0.055); border-color: rgba(255,255,255,0.16); }
      .tile p { color: var(--muted); margin: 12px 0 0; font-size: 0.96rem; }
      .tile .index {
        font-family: 'Geist Mono', ui-monospace, monospace;
        font-size: 0.78rem;
        color: var(--subtle);
        margin-bottom: 24px;
      }
      .section-heading { display: flex; justify-content: space-between; align-items: end; gap: 18px; margin-bottom: 18px; }
      .section-heading p { color: var(--muted); margin: 8px 0 0; max-width: 540px; }
      .posts { display: grid; gap: 14px; margin-top: 20px; }
      .post { padding: 24px; transition: transform .18s ease, background .18s ease, border-color .18s ease; }
      .post h2 { margin: 0 0 10px; font-size: clamp(1.2rem, 2.4vw, 1.58rem); letter-spacing: -0.035em; }
      .meta { color: var(--muted); font-size: 0.92rem; }
      .tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 14px; }
      .tag {
        border: 1px solid rgba(255,255,255,0.10);
        border-radius: 999px;
        padding: 4px 10px;
        color: #cfd4dd;
        background: rgba(255,255,255,0.035);
        font-family: 'Geist Mono', ui-monospace, monospace;
        font-size: 0.74rem;
      }
      .terminal-card {
        margin-top: 28px;
        padding: 0;
        overflow: hidden;
        background: rgba(0,0,0,0.28);
      }
      .terminal-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 14px;
        border-bottom: 1px solid var(--line-soft);
        color: var(--subtle);
        font-family: 'Geist Mono', ui-monospace, monospace;
        font-size: 0.76rem;
      }
      .dot { width: 10px; height: 10px; border-radius: 50%; background: var(--subtle); }
      .dot.red { background: #ff5b4f; } .dot.yellow { background: #f59e0b; } .dot.green { background: var(--green); }
      .terminal-body {
        padding: 20px;
        font-family: 'Geist Mono', ui-monospace, monospace;
        color: #d7dce6;
        font-size: 0.88rem;
        line-height: 1.85;
      }
      .terminal-body .prompt { color: var(--green); }
      .terminal-body .muted { color: var(--subtle); }
      article.prose { max-width: 820px; padding: clamp(26px, 5vw, 58px); }
      article.prose p, article.prose li { color: #d5d9e2; }
      article.prose a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
      article.prose code { background: rgba(255,255,255,0.08); padding: 0.1em 0.36em; border-radius: 6px; font-family: 'Geist Mono', ui-monospace, monospace; }
      article.prose pre { overflow-x: auto; padding: 18px; border-radius: 14px; background: rgba(0,0,0,0.32); border: 1px solid var(--line); }
      article.prose hr { border: 0; border-top: 1px solid var(--line); margin: 34px 0; }
      footer { color: var(--subtle); border-top: 1px solid var(--line-soft); padding: 28px 0 40px; font-size: 0.92rem; }
      @media (max-width: 820px) {
        .shell { width: min(100% - 28px, 1120px); }
        nav { align-items: flex-start; flex-direction: column; }
        .grid { grid-template-columns: 1fr; }
        .hero { padding: 30px; }
        main { padding-top: 34px; }
        .section-heading { display: block; }
      }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { scroll-behavior: auto !important; transition: none !important; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="shell">
        <a class="brand" href="/"><span class="brand-mark">7s</span><span>777stay 技术博客</span></a>
        <div class="nav-links">
          <a href="/blog/">Blog</a>
          <a href="/about/">About</a>
          <a href="https://github.com/777stay" target="_blank" rel="noreferrer">GitHub</a>
        </div>
      </nav>
    </header>
    <main class="shell">
      <slot />
    </main>
    <footer class="shell">
      <span>© {new Date().getFullYear()} 777stay · engineering notes, compounded.</span>
    </footer>
  </body>
</html>
