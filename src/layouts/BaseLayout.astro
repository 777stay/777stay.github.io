---
const {
  title = '777stay 的数字花园',
  description = '记录技术、职业、投资、心理成长与生活复利。',
} = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f7f3ea;
        --paper: #fffaf1;
        --ink: #23201c;
        --muted: #6f675d;
        --line: #e3d7c5;
        --accent: #8a5cf6;
        --accent-2: #f59e0b;
        --shadow: 0 20px 60px rgba(54, 44, 30, 0.10);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans SC", "PingFang SC", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(138, 92, 246, 0.16), transparent 28rem),
          radial-gradient(circle at bottom right, rgba(245, 158, 11, 0.14), transparent 24rem),
          var(--bg);
        color: var(--ink);
        line-height: 1.75;
      }
      a { color: inherit; text-decoration: none; }
      a:hover { color: var(--accent); }
      .shell { width: min(1040px, calc(100% - 32px)); margin: 0 auto; }
      header.site-header { padding: 28px 0 18px; }
      nav { display: flex; justify-content: space-between; align-items: center; gap: 20px; }
      .brand { font-weight: 800; letter-spacing: -0.03em; font-size: 1.15rem; }
      .nav-links { display: flex; gap: 18px; color: var(--muted); font-size: 0.96rem; }
      main { padding: 18px 0 72px; }
      .card {
        background: rgba(255, 250, 241, 0.82);
        border: 1px solid var(--line);
        border-radius: 28px;
        box-shadow: var(--shadow);
      }
      .hero { padding: clamp(32px, 7vw, 80px); }
      .eyebrow { color: var(--accent); font-weight: 700; margin: 0 0 12px; }
      h1, h2, h3 { line-height: 1.2; letter-spacing: -0.04em; }
      h1 { font-size: clamp(2.3rem, 7vw, 5.8rem); margin: 0 0 20px; }
      h2 { font-size: clamp(1.55rem, 3vw, 2.2rem); margin-top: 0; }
      .lead { color: var(--muted); font-size: clamp(1.05rem, 2vw, 1.25rem); max-width: 720px; }
      .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 18px; }
      .tile { padding: 22px; }
      .tile p { color: var(--muted); margin-bottom: 0; }
      .posts { display: grid; gap: 16px; margin-top: 20px; }
      .post { padding: 24px; }
      .post h2 { margin: 0 0 8px; font-size: 1.35rem; }
      .meta { color: var(--muted); font-size: 0.92rem; }
      .tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
      .tag { border: 1px solid var(--line); border-radius: 999px; padding: 2px 10px; color: var(--muted); font-size: 0.82rem; }
      article.prose { max-width: 760px; padding: clamp(24px, 5vw, 54px); }
      article.prose a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
      article.prose code { background: #efe5d6; padding: 0.1em 0.35em; border-radius: 6px; }
      footer { color: var(--muted); border-top: 1px solid var(--line); padding: 28px 0 40px; }
      @media (max-width: 760px) {
        nav { align-items: flex-start; flex-direction: column; }
        .grid { grid-template-columns: 1fr; }
        .hero { padding: 28px; }
      }
    </style>
  </head>
  <body>
    <header class="site-header shell">
      <nav>
        <a class="brand" href="/">777stay 的数字花园</a>
        <div class="nav-links">
          <a href="/blog/">Blog</a>
          <a href="/about/">About</a>
          <a href="https://github.com/777stay" target="_blank">GitHub</a>
        </div>
      </nav>
    </header>
    <main class="shell">
      <slot />
    </main>
    <footer class="shell">
      <span>© {new Date().getFullYear()} 777stay · build in public, compound quietly.</span>
    </footer>
  </body>
</html>
