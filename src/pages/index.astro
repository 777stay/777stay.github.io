---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate, getAllTags, getReadingTime, getSlug, sortPosts } from '../utils/blog';

const posts = sortPosts(await getCollection('blog'));
const featuredPosts = posts.slice(0, 5);
const tags = getAllTags(posts).slice(0, 12);
---
<BaseLayout>
  <section class="hero card">
    <p class="eyebrow">Engineering notes · Backend · AI workflow</p>
    <h1>把每一次工程实践，沉淀成可复用的技术资产。</h1>
    <p class="lead">
      这里记录 777stay 的后端开发、系统设计、AI 工具链、源码阅读和项目复盘。写作目标不是热闹，而是把问题、方案、验证和复盘留成以后还能调用的知识资产。
    </p>
    <div class="actions">
      <a class="button primary" href="/blog/">阅读文章</a>
      <a class="button ghost" href="/tags/">浏览标签</a>
      <a class="button ghost" href="https://github.com/777stay" target="_blank" rel="noreferrer">查看 GitHub</a>
    </div>
  </section>

  <section class="grid" aria-label="topics">
    <div class="tile card">
      <div class="index">01 / PRACTICE</div>
      <h2>工程实践</h2>
      <p>后端开发、数据库、缓存、消息队列、部署、可观测性，以及真实项目中的取舍。</p>
    </div>
    <div class="tile card">
      <div class="index">02 / AI WORKFLOW</div>
      <h2>AI 工具链</h2>
      <p>记录 AI 辅助编码、测试、调试、文档生成和个人知识管理的实践方法。</p>
    </div>
    <div class="tile card">
      <div class="index">03 / RETROSPECTIVE</div>
      <h2>项目复盘</h2>
      <p>把问题背景、方案设计、踩坑记录和验证结果整理成下次可以复用的经验。</p>
    </div>
  </section>

  <section style="margin-top: 56px;">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Latest writing</p>
        <h2>最新文章</h2>
      </div>
      <p>借鉴 AstroPaper / PaperMod / Tailwind Nextjs Starter Blog：把文章流作为首页核心，优先服务长期阅读与检索。</p>
    </div>
    <div class="posts">
      {featuredPosts.map((post) => (
        <a class="post card" href={`/blog/${getSlug(post.id)}/`}>
          <h2>{post.data.title}</h2>
          <div class="meta">{formatDate(post.data.pubDate)} · {getReadingTime(post.body)} · {post.data.description}</div>
          <div class="tags">
            {post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="card" style="margin-top: 28px; padding: 24px;">
    <div class="section-heading" style="margin-bottom: 0;">
      <div>
        <p class="eyebrow">Tags</p>
        <h2>主题索引</h2>
      </div>
      <p>标签是技术博客的第二入口。后续文章多起来后，可以按“后端 / 系统设计 / AI 工具链 / 源码阅读”沉淀系列。</p>
    </div>
    <div class="tag-cloud">
      {tags.map(([tag, count]) => <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>#{tag} · {count}</a>)}
    </div>
  </section>
</BaseLayout>
