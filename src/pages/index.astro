---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const getSlug = (id: string) => id.replace(/\.mdx?$/, '');
---
<BaseLayout>
  <section class="hero card">
    <p class="eyebrow">Engineering notes · AI tools · System design</p>
    <h1>记录技术积累，沉淀工程能力。</h1>
    <p class="lead">
      这里是 777stay 的技术博客：记录后端开发、系统设计、AI 工具链、源码阅读和项目复盘，把零散经验沉淀成可复用的工程资产。
    </p>
  </section>

  <section class="grid" aria-label="topics">
    <div class="tile card">
      <h2>工程实践</h2>
      <p>后端开发、数据库、缓存、消息队列、部署、可观测性，以及真实项目中的取舍。</p>
    </div>
    <div class="tile card">
      <h2>AI 工具链</h2>
      <p>记录 AI 辅助编码、测试、调试、文档生成和个人知识管理的实践方法。</p>
    </div>
    <div class="tile card">
      <h2>项目复盘</h2>
      <p>把问题背景、方案设计、踩坑记录和验证结果整理成下次可以复用的经验。</p>
    </div>
  </section>

  <section style="margin-top: 42px;">
    <h2>最新文章</h2>
    <div class="posts">
      {posts.map((post) => (
        <a class="post card" href={`/blog/${getSlug(post.id)}/`}>
          <h2>{post.data.title}</h2>
          <div class="meta">{post.data.pubDate.toLocaleDateString('zh-CN')} · {post.data.description}</div>
          <div class="tags">
            {post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
