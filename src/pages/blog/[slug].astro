---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { formatDate, getReadingTime, getSlug } from '../../utils/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: getSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={`${post.data.title} · 777stay 技术博客`} description={post.data.description}>
  <article class="prose card">
    <p class="eyebrow">{formatDate(post.data.pubDate)} · {getReadingTime(post.body)}</p>
    <h1 style="font-size: clamp(2rem, 5vw, 4rem);">{post.data.title}</h1>
    <p class="lead">{post.data.description}</p>
    <div class="tags">
      {post.data.tags.map((tag) => <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>#{tag}</a>)}
    </div>
    <hr />
    <Content />
  </article>
</BaseLayout>
