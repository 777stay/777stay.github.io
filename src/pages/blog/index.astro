---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const getSlug = (id: string) => id.replace(/\.mdx?$/, '');
---
<BaseLayout title="Blog · 777stay 技术博客">
  <section class="hero card" style="padding-block: clamp(30px, 6vw, 64px);">
    <p class="eyebrow">Archive</p>
    <h1 style="font-size: clamp(2.4rem, 6vw, 4.6rem);">技术文章归档</h1>
    <p class="lead">按时间沉淀工程实践、系统设计、AI 工具链和项目复盘。目标不是日更，而是每篇文章都能在未来复用。</p>
  </section>
  <div class="posts" style="margin-top: 28px;">
    {posts.map((post) => (
      <a class="post card" href={`/blog/${getSlug(post.id)}/`}>
        <h2>{post.data.title}</h2>
        <div class="meta">{post.data.pubDate.toLocaleDateString('zh-CN')} · {post.data.description}</div>
        <div class="tags">
          {post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
