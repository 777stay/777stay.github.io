---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate, getAllTags, getReadingTime, getSlug, sortPosts } from '../../utils/blog';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('blog'));
  return getAllTags(posts).map(([tag]) => ({
    params: { tag },
    props: { tag, posts: posts.filter((post) => post.data.tags.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
---
<BaseLayout title={`#${tag} · 777stay 技术博客`} description={`777stay 技术博客中 #${tag} 标签下的文章。`}>
  <section class="hero card" style="padding-block: clamp(30px, 6vw, 64px);">
    <p class="eyebrow">Tag</p>
    <h1 style="font-size: clamp(2.4rem, 6vw, 4.6rem);">#{tag}</h1>
    <p class="lead">这个主题下共有 {posts.length} 篇文章。</p>
  </section>
  <section class="card" style="margin-top: 28px; padding: clamp(20px, 4vw, 34px);">
    <div class="archive-list">
      {posts.map((post) => (
        <article class="archive-item">
          <time class="archive-date" datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          <div>
            <h2><a href={`/blog/${getSlug(post.id)}/`}>{post.data.title}</a></h2>
            <p class="archive-summary">{post.data.description}</p>
            <div class="tags">
              <span class="reading-time">{getReadingTime(post.body)}</span>
              {post.data.tags.map((item) => <a class="tag" href={`/tags/${encodeURIComponent(item)}/`}>#{item}</a>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
